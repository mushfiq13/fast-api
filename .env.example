APP_NAME=FastAPI Lab 2

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# PostgreSQL Configuration
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/my_db

# MongoDB Configuration
MONGODB_URL=mongodb://mongodb:mongodb@localhost:27017
MONGODB_DB_NAME=my_db

# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=notes

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=3600
